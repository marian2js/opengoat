{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenGoat",
  "version": "2026.4.7-3",
  "identifier": "com.opengoat.app",
  "build": {
    "beforeDevCommand": "pnpm --dir ../../ desktop:frontend:dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm --dir ../../ desktop:frontend:release-build && pnpm --dir ../../ sidecar:bundle",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenGoat",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "macOS": {
      "signingIdentity": "-"
    },
    "resources": {
      "../../../packages/sidecar/.bundle/": "sidecar/"
    },
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
