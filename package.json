{
  "name": "@opengoat/opengoat-monorepo",
  "version": "2026.4.7-2",
  "private": true,
  "description": "OpenGoat monorepo workspace",
  "type": "module",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "build": "pnpm --filter @opengoat/contracts build && pnpm --filter @opengoat/core build && pnpm --filter opengoat build",
    "clean": "pnpm --filter @opengoat/contracts clean && pnpm --filter @opengoat/core clean && pnpm --filter opengoat clean && rm -rf coverage",
    "dev": "node scripts/dev-browser.mjs",
    "dev:cli": "pnpm --filter opengoat dev",
    "desktop:build": "pnpm --filter @opengoat/desktop tauri build",
    "desktop:dev": "pnpm --filter @opengoat/desktop tauri dev",
    "desktop:frontend:build": "pnpm --filter @opengoat/desktop build",
    "desktop:frontend:dev": "pnpm --filter @opengoat/desktop dev",
    "desktop:frontend:release-build": "pnpm --filter @opengoat/contracts build && pnpm --filter @opengoat/desktop exec vite build",
    "sidecar:bundle": "pnpm --filter @opengoat/sidecar bundle:prepare",
    "sidecar:build": "pnpm --filter @opengoat/sidecar build",
    "sidecar:dev": "pnpm --filter @opengoat/sidecar dev",
    "rust:check": "cargo check --workspace",
    "rust:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "rust:fmt": "cargo fmt --all",
    "rust:fmt:check": "cargo fmt --all --check",
    "start": "pnpm --filter opengoat start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm --filter @opengoat/contracts build && pnpm --filter @opengoat/core typecheck && pnpm --filter opengoat typecheck",
    "changeset": "changeset",
    "release:check-version": "node scripts/sync-version.mjs --check",
    "release:sync-version": "node scripts/sync-version.mjs",
    "version-packages": "node scripts/release.mjs",
    "release": "node scripts/release.mjs",
    "prepare": "husky",
    "vendor-skills": "npx tsx packages/core/src/core/skills/scripts/vendor-skills.ts"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "pnpm": {
    "overrides": {
      "lodash-es": ">=4.17.23",
      "@trpc/client": "10.45.4",
      "@trpc/server": "10.45.4"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/node": "^22.13.4",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.5"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "sql.js": "^1.13.0"
  }
}
