{
  "name": "@opengoat/sidecar",
  "private": true,
  "version": "2026.4.7-2",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
